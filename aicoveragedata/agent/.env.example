# Copy this file to aicoveragedata/agent/.env and fill in your real key.
# Do not commit the .env file.

OPENAI_API_KEY=key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
AGENT_USE_DSPY=true
AGENT_DSPY_FALLBACK=true
AGENT_MAX_CONTEXT_CHARS=18000
AGENT_MAX_HISTORY_MESSAGES=16
AGENT_MAX_STORED_MESSAGE_CHARS=4000
